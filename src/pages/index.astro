---
// Hello Ratzle! - Cat-themed page
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hello Ratzle! - SkyKeep</title>
    <style>
        body {
            font-family: 'Comic Sans MS', 'Chalkboard SE', 'Comic Neue', cursive, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #ff9a56 0%, #ff6b9d 50%, #feca57 100%);
            color: #2c3e50;
            position: relative;
            overflow: hidden;
        }
        .container {
            text-align: center;
            padding: 2rem;
            background: rgba(255, 255, 255, 0.9);
            border-radius: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            position: relative;
            z-index: 1;
        }
        h1 {
            font-size: 4rem;
            margin: 0;
            font-weight: bold;
            color: #e74c3c;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }
        .cat-emoji {
            font-size: 5rem;
            display: block;
            margin-bottom: 1rem;
            animation: bounce 2s infinite;
        }
        .paw {
            position: absolute;
            font-size: 2rem;
            opacity: 0.3;
            animation: float 4s infinite ease-in-out;
        }
        .paw:nth-child(1) { top: 10%; left: 15%; animation-delay: 0s; }
        .paw:nth-child(2) { top: 20%; right: 20%; animation-delay: 1s; }
        .paw:nth-child(3) { bottom: 15%; left: 20%; animation-delay: 2s; }
        .paw:nth-child(4) { bottom: 25%; right: 15%; animation-delay: 1.5s; }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(10deg); }
        }
    </style>
</head>
<body>
    <div class="paw">🐾</div>
    <div class="paw">🐾</div>
    <div class="paw">🐾</div>
    <div class="paw">🐾</div>

    <div class="container">
        <span class="cat-emoji">🐱</span>
        <h1>Hello Ratzle!</h1>
    </div>
</body>
</html>
